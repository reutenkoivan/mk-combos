    "validate:docs": "turbo run validate:docs"
  },
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "turbo": "2.10.2",
    "typescript": "6.0.3"
  }
}
