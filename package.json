{
  "name": "mk-combos",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/*",
    "mkxl/*",
    "mk1/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run root:check",
    "ci": "turbo run root:check root:typecheck root:test root:sherif root:knip root:arch:check root:hooks:validate root:secrets:check typecheck test build validate:data validate:docs storybook:build --concurrency=100%",
    "dev": "turbo run dev",
    "format": "biome format . --write",
    "format:check": "turbo run root:format:check",
    "hooks:install": "lefthook install",
    "hooks:validate": "turbo run root:hooks:validate",
    "knip": "turbo run root:knip",
    "lint": "turbo run root:lint",
    "playwright:install": "playwright install chromium",
    "secrets:check": "turbo run root:secrets:check",
    "secrets:check:staged": "gitleaks git --staged --redact --no-banner .",
    "sherif": "turbo run root:sherif",
    "arch:check": "turbo run root:arch:check",
    "arch:graph": "sheriff export > sheriff-graph.json",
    "root:arch:check": "sheriff verify",
    "root:check": "biome check .",
    "root:format:check": "biome format .",
    "root:hooks:validate": "lefthook validate",
    "root:knip": "knip",
    "root:lint": "biome lint .",
    "root:secrets:check": "gitleaks git --redact --no-banner .",
    "root:sherif": "sherif",
    "root:test": "vitest run",
    "root:typecheck": "tsc --noEmit -p tsconfig.json",
    "storybook:build": "turbo run storybook:build",
    "test": "turbo run root:test test",
    "typecheck": "turbo run root:typecheck typecheck",
    "validate:data": "turbo run validate:data",
    "validate:docs": "turbo run validate:docs"
  },
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@playwright/test": "1.61.1",
    "@softarc/sheriff-core": "0.19.6",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@types/node": "25.6.2",
    "jsdom": "29.1.1",
    "knip": "6.23.0",
    "lefthook": "2.1.9",
    "sherif": "1.12.0",
    "storybook": "10.4.6",
    "turbo": "2.10.2",
    "typescript": "6.0.3",
    "vite": "8.1.2",
    "vitest": "4.1.9"
  }
}
